{
    "name": "papier/papier",
    "description": "A comprehensive PHP library for generating and reading PDF documents, implementing ISO 32000-1:2008 (PDF 1.7)",
    "type": "library",
    "homepage": "https://papier.io",
    "license": "MIT",
    "authors": [
        {
            "name": "Mikael Carlavan",
            "email": "mikael@camina.dev",
            "homepage": "https://camina.dev",
            "role": "Developer"
        }
    ],
    "keywords": ["pdf", "pdf-generator", "pdf-reader", "iso32000", "pdf17"],
    "require": {
        "php": ">=8.1",
        "ext-zlib": "*",
        "ext-mbstring": "*",
        "ext-openssl": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "Papier\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Papier\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    }
}
